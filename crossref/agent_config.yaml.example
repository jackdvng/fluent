# Band agent credentials - one block per agent.
#
# Register each agent at https://app.band.ai/agents -> New Agent -> External Agent.
# Copy the API key from the popup (shown once!) and the Agent UUID from settings.
#
# IMPORTANT: the agent's *display name* on Band must match what the other agents
# @mention. Name them exactly:
#   WebScout, ScholarBot, TubeDigger, Synthesizer
#
# Copy this file to agent_config.yaml and fill in real values:
#   cp agent_config.yaml.example agent_config.yaml

webscout:
  agent_id: "uuid-for-webscout-agent"
  api_key: "band-api-key-for-webscout"

scholarbot:
  agent_id: "uuid-for-scholarbot-agent"
  api_key: "band-api-key-for-scholarbot"

tubedigger:
  agent_id: "uuid-for-tubedigger-agent"
  api_key: "band-api-key-for-tubedigger"

synthesizer:
  agent_id: "uuid-for-synthesizer-agent"
  api_key: "band-api-key-for-synthesizer"
